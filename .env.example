# franchisetech — Environment Variables
# Copy to .env.local and fill in real values.
# Never commit .env.local or any file containing real secrets.
#
# See docs/LOCAL_DEVELOPMENT.md for setup instructions.

# ─── Supabase (required) ────────────────────────────────────────────────────
# These two are embedded in the browser bundle at build time (NEXT_PUBLIC_).
# For local dev, use your production Supabase URL + anon key (read-only from browser).
# The anon key is safe to use locally — RLS policies enforce row-level security.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only service role key — never expose to browser.
# Required at runtime for admin operations (team management, billing webhooks, sensors).
# For local build verification only, a placeholder is sufficient.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── App URL ────────────────────────────────────────────────────────────────
# Full public URL of the app. Used in email links, OAuth redirects, etc.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public asset host for email images. Keep production/public so email clients can load the logo in local tests.

# ─── Chatwoot (server-only — widget identity HMAC) ───────────────────────────
# Inbox → Settings → Configuration → Identity Validation → copy token.
# Enables reliable setUser() for all logged-in app users (not only admin).
CHATWOOT_HMAC_TOKEN=

# Required at runtime for billing flows. Use placeholder for local build.
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
# Stripe price IDs — use EITHER the legacy names (starter/pro) OR the new names (core/operations).
# The code reads both; whichever is set wins. Set the real Stripe price ID, not a placeholder.
# Legacy names (still supported):
STRIPE_STARTER_PRICE_ID=price_placeholder_starter_monthly
STRIPE_PRO_PRICE_ID=price_placeholder_pro_monthly
STRIPE_SCALE_PRICE_ID=price_placeholder_scale_monthly
STRIPE_MULTI_LOCATION_PRICE_ID=price_placeholder_multi_location_monthly
# Annual billing prices (20% discount — create in Stripe Dashboard first):
STRIPE_STARTER_ANNUAL_PRICE_ID=price_placeholder_starter_annual
STRIPE_PRO_ANNUAL_PRICE_ID=price_placeholder_pro_annual
STRIPE_SCALE_ANNUAL_PRICE_ID=price_placeholder_scale_annual
STRIPE_MULTI_LOCATION_ANNUAL_PRICE_ID=price_placeholder_multi_location_annual
# New canonical names (preferred — these take priority over legacy names above if both are set):
STRIPE_CORE_MONTHLY_PRICE_ID=
STRIPE_CORE_ANNUAL_PRICE_ID=
STRIPE_OPERATIONS_MONTHLY_PRICE_ID=
STRIPE_OPERATIONS_ANNUAL_PRICE_ID=
STRIPE_SCALE_MONTHLY_PRICE_ID=
STRIPE_MULTILOCATION_MONTHLY_PRICE_ID=
STRIPE_MULTILOCATION_ANNUAL_PRICE_ID=

# ─── Resend (server-only) ───────────────────────────────────────────────────
# Required at runtime for transactional email. Use placeholder for local build.
RESEND_API_KEY=re_placeholder
RESEND_FROM_EMAIL=noreply@franchisetech.ro

# ─── Internal secrets (server-only) ─────────────────────────────────────────
# Use placeholder values for local build. Required at runtime for API endpoints.
CRON_SECRET=placeholder-cron-secret
# Cron: POST /api/cron/owner-digest every 5 minutes (n8n or crontab) with Bearer CRON_SECRET
MARKETING_UPLOAD_TOKEN=placeholder-upload-token
SENSOR_INGEST_SECRET=placeholder-sensor-secret

# ─── Feature flags (optional) ────────────────────────────────────────────────
# Set to "true" to enable. Leave blank or "false" to disable.
NEXT_PUBLIC_ENABLE_DEMO_TOOLS=false
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=false

# Partner program — open recruitment only after Dolce Nera loop is proven (see docs/growth/P0-REFERRAL-PLAYBOOK.md)
PARTNER_PROGRAM_OPEN=false

# ─── Analytics (optional) ────────────────────────────────────────────────────
# Google Analytics 4 — use NEXT_PUBLIC_GA_MEASUREMENT_ID (preferred) or legacy NEXT_PUBLIC_GA_ID.
# Both are supported; NEXT_PUBLIC_GA_MEASUREMENT_ID takes priority if both are set.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GA_ID=

# Meta (Facebook) Pixel — Pixel ID from Meta Events Manager
NEXT_PUBLIC_META_PIXEL_ID=

# LinkedIn Insight Tag — Partner ID from LinkedIn Campaign Manager → Insight Tag
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=

# PostHog (EU cloud) — project token from PostHog → Project settings
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# GA4 Measurement Protocol API secret (Admin > Data Streams > [stream] > Measurement Protocol API secrets).
# Used server-side to fire a "purchase" event on confirmed Stripe revenue (see lib/analytics/server-conversions.ts).
GA4_API_SECRET=

# Google Ads offline conversion upload (server-side) — fires on confirmed Stripe revenue, not page loads.
# Requires: an OAuth2 client (Google Cloud Console) authorized for the Google Ads API, a refresh token for an
# account with access to the Ads account, the account's developer token, and a Conversion Action already
# created in Google Ads (Tools & Settings > Conversions) to get its numeric ID.
GOOGLE_ADS_OAUTH_CLIENT_ID=
GOOGLE_ADS_OAUTH_CLIENT_SECRET=
GOOGLE_ADS_OAUTH_REFRESH_TOKEN=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_CONVERSION_ACTION_ID=
# Only needed if GOOGLE_ADS_CUSTOMER_ID sits under a manager (MCC) account:
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# ─── Booking / Demo ──────────────────────────────────────────────────────────
# Cal.com or Calendly URL for "Book a Demo" CTA. Leave blank to hide the button.
NEXT_PUBLIC_DEMO_BOOKING_URL=

# Loops.so (server-only) — API key from https://app.loops.so/settings?page=api
LOOPS_API_KEY=

# Google Search Console site verification token (optional — enables ownership verification meta tag).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ─── Database backup (server-side only — not needed for local dev) ──────────
# Direct Postgres connection for pg_dump — must be the "Direct connection" URI,
# NOT the pooler (port 6543). Get from: Supabase Dashboard → Settings → Database.
# Must also be set in /var/www/fridgeproof/.env.local on do-server.
DIRECT_DB_URL=postgresql://postgres.yourproject:password@db.yourproject.supabase.co:5432/postgres
